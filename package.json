{
  "name": "bookmind-backend",
  "version": "1.0.0",
  "description": "BookMind Reading Tracker API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node -e \"require('./db').query(require('fs').readFileSync('../database/schema.sql','utf8')).then(()=>{console.log('Schema applied');process.exit()}).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
